/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://api.github.com; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; object-src 'none'

# Safe to cache forever: index.html references /app.js?v=<sha>, stamped at
# deploy time, so every engine change ships under a brand-new URL.
/app.js
  Cache-Control: public, max-age=31536000, immutable

# All image assets share a one-day edge cache. Covers orb.webp, og.png, and any
# future asset without a per-file rule.
/assets/*
  Cache-Control: public, max-age=86400

/
  Cache-Control: public, max-age=0, must-revalidate
